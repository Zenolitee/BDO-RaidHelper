{
  "name": "nw-helper",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:css && tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "npm run build:css && tsc",
    "build:css": "npx @tailwindcss/cli -i ./src/styles/input.css -o ./src/public/styles.css --minify",
    "qa:web": "npm run build && node scripts/qa-web-smoke.mjs",
    "register:commands": "tsx src/register-commands.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "discord.js": "^14.19.3",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "nanoid": "^5.1.5"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "@types/express": "^5.0.2",
    "@types/node": "^22.15.21",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
